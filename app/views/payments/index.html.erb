<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">Payments</h1>
  <%= link_to "Record payment", new_payment_path, class: "btn btn-primary" %>
</div>

<% if @payments.any? %>
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead>
        <tr><th>Date</th><th>Member</th><th>Method</th><th>Notes</th><th class="text-end">Amount</th><th></th></tr>
      </thead>
      <tbody>
        <% @payments.each do |payment| %>
          <tr>
            <td><%= payment.paid_on %></td>
            <td><%= link_to payment.member.name, payment.member %></td>
            <td><%= payment.payment_method.humanize %></td>
            <td><%= payment.notes %></td>
            <td class="text-end"><%= money(payment.amount) %></td>
            <td class="text-end">
              <%= link_to "Edit", edit_payment_path(payment), class: "btn btn-sm btn-outline-secondary" %>
              <%= link_to "Delete", payment, data: { turbo_method: :delete, turbo_confirm: "Delete this payment?" }, class: "btn btn-sm btn-outline-danger" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-muted">No payments yet. <%= link_to "Record one", new_payment_path %>.</p>
<% end %>
