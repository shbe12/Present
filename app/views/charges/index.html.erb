<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">Charges</h1>
  <%= link_to "New charge", new_charge_path, class: "btn btn-primary" %>
</div>

<% if @charges.any? %>
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead>
        <tr><th>Date</th><th>Member</th><th>Type</th><th>Description</th><th class="text-end">Amount</th><th></th></tr>
      </thead>
      <tbody>
        <% @charges.each do |charge| %>
          <tr>
            <td><%= charge.due_date || charge.created_at.to_date %></td>
            <td><%= link_to charge.member.name, charge.member %></td>
            <td>
              <%= charge.charge_type.humanize %>
              <% if charge.automatic? %><span class="badge text-bg-light text-muted">auto</span><% end %>
            </td>
            <td><%= charge.description %></td>
            <td class="text-end"><%= money(charge.amount) %></td>
            <td class="text-end">
              <% if charge.automatic? %>
                <span class="text-muted small">via attendance</span>
              <% else %>
                <%= link_to "Edit", edit_charge_path(charge), class: "btn btn-sm btn-outline-secondary" %>
                <%= link_to "Delete", charge, data: { turbo_method: :delete, turbo_confirm: "Delete this charge?" }, class: "btn btn-sm btn-outline-danger" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-muted">No charges yet. <%= link_to "Create one", new_charge_path %>.</p>
<% end %>
