<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">Attendance</h1>
  <%= link_to "Record attendance", new_attendance_path, class: "btn btn-primary" %>
</div>

<% if @attendances.any? %>
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead>
        <tr><th>Date</th><th>Member</th><th>Status</th><th>Notes</th><th></th></tr>
      </thead>
      <tbody>
        <% @attendances.each do |attendance| %>
          <tr>
            <td><%= attendance.date %></td>
            <td><%= link_to attendance.member.name, attendance.member %></td>
            <td><%= attendance_status_badge(attendance.status) %></td>
            <td><%= attendance.notes %></td>
            <td class="text-end">
              <%= link_to "Edit", edit_attendance_path(attendance), class: "btn btn-sm btn-outline-secondary" %>
              <%= link_to "Delete", attendance, data: { turbo_method: :delete, turbo_confirm: "Delete this record? Any automatic charge will be removed." }, class: "btn btn-sm btn-outline-danger" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-muted">No attendance recorded yet. <%= link_to "Record the first", new_attendance_path %>.</p>
<% end %>
