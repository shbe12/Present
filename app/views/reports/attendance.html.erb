<h1 class="h3 mb-4">Attendance report</h1>

<div class="row g-3 mb-4">
  <% %w[present late no_show excused].each do |status| %>
    <div class="col-6 col-md-3">
      <div class="card text-center">
        <div class="card-body">
          <h6 class="card-subtitle text-muted"><%= status.humanize %></h6>
          <p class="display-6 mb-0"><%= @counts_by_status.fetch(status, 0) %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>

<% if @attendances.any? %>
  <div class="table-responsive">
    <table class="table table-sm align-middle">
      <thead><tr><th>Date</th><th>Member</th><th>Status</th><th>Notes</th></tr></thead>
      <tbody>
        <% @attendances.each do |attendance| %>
          <tr>
            <td><%= attendance.date %></td>
            <td><%= link_to attendance.member.name, attendance.member %></td>
            <td><%= attendance_status_badge(attendance.status) %></td>
            <td><%= attendance.notes %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-muted">No attendance recorded yet.</p>
<% end %>
