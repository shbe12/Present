<h1 class="h3 mb-4">Treasury report</h1>

<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="card"><div class="card-body">
      <h6 class="card-subtitle text-muted">Income (payments)</h6>
      <p class="display-6 mb-0 text-success"><%= money(@total_income) %></p>
    </div></div>
  </div>
  <div class="col-md-4">
    <div class="card"><div class="card-body">
      <h6 class="card-subtitle text-muted">Expenses</h6>
      <p class="display-6 mb-0 text-danger"><%= money(@total_expenses) %></p>
    </div></div>
  </div>
  <div class="col-md-4">
    <div class="card"><div class="card-body">
      <h6 class="card-subtitle text-muted">Balance</h6>
      <p class="display-6 mb-0 <%= "text-danger" if @treasury_balance.negative? %>"><%= money(@treasury_balance) %></p>
    </div></div>
  </div>
</div>

<div class="row g-4">
  <div class="col-md-6">
    <h2 class="h5">Income by method</h2>
    <% if @income_by_method.any? %>
      <table class="table table-sm">
        <tbody>
          <% @income_by_method.each do |method, amount| %>
            <tr><td><%= method.humanize %></td><td class="text-end"><%= money(amount) %></td></tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-muted">No income recorded.</p>
    <% end %>
  </div>

  <div class="col-md-6">
    <h2 class="h5">Expenses by category</h2>
    <% if @expenses_by_category.any? %>
      <table class="table table-sm">
        <tbody>
          <% @expenses_by_category.each do |category, amount| %>
            <tr><td><%= category.humanize %></td><td class="text-end"><%= money(amount) %></td></tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-muted">No expenses recorded.</p>
    <% end %>
  </div>
</div>
