<%= turbo_stream_from "members" %>

<h1 class="h3 mb-4">Member balances</h1>

<% total_outstanding = @members.sum(&:balance_due) %>

<div class="card mb-4">
  <div class="card-body d-flex justify-content-between align-items-center">
    <h6 class="card-subtitle text-muted mb-0">Total outstanding across all members</h6>
    <span class="h4 mb-0 <%= "text-danger" if total_outstanding.negative? %>"><%= money(total_outstanding) %></span>
  </div>
</div>

<% if @members.any? %>
  <div class="table-responsive">
    <table class="table align-middle">
      <thead>
        <tr><th>Member</th><th class="text-end">Charged</th><th class="text-end">Paid</th><th class="text-end">Balance due</th></tr>
      </thead>
      <tbody>
        <% @members.each do |member| %>
          <% charged = member.charges.sum(&:amount); paid = member.payments.sum(&:amount) %>
          <tr>
            <td><%= link_to member.name, member %></td>
            <td class="text-end"><%= link_to money(charged), charges_path(member_id: member.id) %></td>
            <td class="text-end"><%= money(paid) %></td>
            <td class="text-end"><%= render "members/balance", member: member %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-muted">No members yet.</p>
<% end %>
